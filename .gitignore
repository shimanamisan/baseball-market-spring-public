# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Gradle
.gradle/
build/

# Claude Code（個人用ローカル設定は追跡しない）
.claude/settings.local.json

# 開発用 DB シードの元データ（旧 baseball-market の本番相当ダンプ＋画像）。
# 開発環境ローカル専用のため追跡しない。リポジトリにコミットするシードは
# db/seed/*.sql（と画像はシード fixture の正規置き場 app/seed-data/images/）側で管理する。
_docs/database/

# ランタイムのユーザーアップロード保存先（app.uploads.path）。
# 環境ごとに増える実アップロードは追跡しない。ディレクトリ自体は .gitkeep で残す。
# シードが参照する fixture 画像は app/seed-data/images/（classpath 外）にコミットしている。
app/src/main/resources/static/uploads/*
!app/src/main/resources/static/uploads/.gitkeep

# 開発データ移行スクリプト（migrate-dev-data.sh export）の出力物。
# 匿名化済みとはいえ DB ダンプ・画像 bundle を含むため追跡しない。
migration-out/
migration-in/
