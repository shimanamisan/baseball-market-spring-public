# 本番環境変数テンプレート。
# コピーして .env を作成し、本番サーバーに配置するか GitHub Secret(PRODUCTION_ENV) の
# base64 元とする。__CHANGE_ME__ は必ず実値に置き換える。実値はコミットしない。
#
#   PRODUCTION_ENV の作り方: base64 -w0 .env  （出力を GitHub Secret に登録）

# ===== Spring プロファイル =====
SPRING_PROFILES_ACTIVE=prod

# ===== GitHub Container Registry =====
REGISTRY_URL=ghcr.io/shimanamisan/baseball-market-spring
IMAGE_TAG=latest

# ===== タイムゾーン =====
TZ=Asia/Tokyo

# ===== データベース（MySQL） =====
# DB_HOST は旧 baseball-market の MySQL との alias 衝突を避けるためコンテナ名で固定する。
DB_HOST=baseball-market-spring-db
DB_NAME=bb_market
DB_USERNAME=bbuser
DB_PASSWORD=__CHANGE_ME__
MYSQL_ROOT_PASSWORD=__CHANGE_ME__

# ===== メール（実 SMTP） =====
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=__CHANGE_ME__
MAIL_PASSWORD=__CHANGE_ME__

# ===== アプリ =====
# メール認証リンクの生成元。本番ドメインを https で指定する（localhost にすると認証リンクが壊れる）。
APP_URL=https://your-domain.example.com
# ランタイムのユーザーアップロード保存先（named volume のマウント先）。
APP_UPLOADS_PATH=/var/lib/baseball-market/uploads
# remember-me 署名キー。十分な長さのランダム値を設定する（例: openssl rand -hex 32）。
REMEMBER_ME_KEY=__CHANGE_ME__
